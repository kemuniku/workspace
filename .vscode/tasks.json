{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "/home/kemuniku/.nimble/bin/nim cpp -d:debug --opt:speed --multimethods:on -o:${fileDirname}/a.out ${file}",
            "group": {
                "kind": "build",      // ビルドタスクとして認識させる
                "isDefault": true     // Cmd + Shift + B で即実行
              },
            "presentation": {
                "focus": false,
                "reveal" : "silent"
            }
        },
        {
            "label": "oj_run",
            "type": "shell",
            "command": "/home/kemuniku/.nimble/bin/nim cpp -d:debug --opt:speed --multimethods:on -o:${fileDirname}/a.out ${file} && cd ${fileDirname} && /home/kemuniku/.local/bin/oj t",
            "group": {
                "kind": "build",
              },
            "presentation": {
                "focus": false
            }
        },
        {
            "label": "oj_sub",
            "type": "shell",
            "command": "/home/kemuniku/atcoder/cplib/tools/expander.o ${fileBasename} -l:/home/kemuniku/atcoder/cplib/ -l:/home/kemuniku/atcoder/Nim-ACL/ -s && cat combined.nim | xsel --clipboard --input && /home/kemuniku/.nimble/bin/nim cpp -d:release --opt:speed --multimethods:on --warning[SmallLshouldNotBeUsed]:off --hints:off -o:a.out combined.nim && /home/kemuniku/.local/bin/oj t",
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": {
                "kind": "build"
            },
            "presentation": {
                "focus": false
            }
        },
        {
            "label": "nim: build current file (for debugging)",
            "command": "nim",
            "args": [
                "compile",
                "-g",
                "--debugger:native",
                "-o:${workspaceRoot}/bin/${fileBasenameNoExtension}",
                "${relativeFile}"
            ],
            "options": {
                "cwd": "${workspaceRoot}"
            },
            "type": "shell",
        }
    ]
}